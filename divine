--  WHITELIST
-- ══════════════════════════════════════════════════════════════
local LEGENDARY = { Aether=true, Arcane=true, Aurora=true, Digital=true, Lunar=true }
local DIVINE    = { Destruction=true, Cosmic=true, Spatial=true, Starscourge=true, Time=true }

local COLOR = {
    Legendary = Color3.fromRGB(255, 170, 0),
    Divine    = Color3.fromRGB(180, 80, 255),
}

local function getRarity(name)
    if LEGENDARY[name] then return "Legendary" end
    if DIVINE[name]    then return "Divine"    end
    return nil
end

local function getPos(obj)
    if obj:IsA("Model") then
        local p = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        return p and p.Position
    elseif obj:IsA("BasePart") then
        return obj.Position
    end
end

local function getMyPos()
    local c = LocalPlayer.Character
    local r = c and c:FindFirstChild("HumanoidRootPart")
    return r and r.Position
end

