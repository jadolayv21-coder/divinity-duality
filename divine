-- ══════════════════════════════════════════════════════════════
--  TRACKING
-- ══════════════════════════════════════════════════════════════
local tracked = {} -- obj -> { bb, bbDist, row, rowDist, loop }

local function registerEssence(obj, rarity)
    if tracked[obj] then return end

    local bb, bbDist     = addESP(obj, rarity)
    local row, rowDist   = addPanelEntry(obj.Name, rarity)

    -- Distance update loop — every 0.5s, much lighter than Heartbeat
    local loop = task.spawn(function()
        while obj and obj.Parent do
            local myPos = getMyPos()
            local esPos = getPos(obj)
            if myPos and esPos then
                local d = math.floor((myPos - esPos).Magnitude)
                local txt = d .. " m"
                if rowDist and rowDist.Parent then rowDist.Text = txt end
                if bbDist  and bbDist.Parent  then bbDist.Text  = txt end
            end
            task.wait(0.5)
        end
    end)

    tracked[obj] = { bb = bb, row = row, loop = loop }

    showPopup(obj.Name, rarity)
    playAlert(rarity)
    print(("[EssenceNotifier] ✅ %s (%s) in SpawnedEssences"):format(obj.Name, rarity))

    -- Cleanup when essence is removed
    obj.AncestryChanged:Connect(function(_, parent)
        if parent ~= nil then return end
        local data = tracked[obj]
        if not data then return end
        if data.bb  and data.bb.Parent  then data.bb:Destroy()  end
        if data.row and data.row.Parent then data.row:Destroy() end
        tracked[obj] = nil
        resizePanel()
        print(("[EssenceNotifier] 🗑 %s despawned/taken"):format(obj.Name))
    end)
end

-- ══════════════════════════════════════════════════════════════
--  WATCH SpawnedEssences ONLY
-- ══════════════════════════════════════════════════════════════
local function checkChild(obj)
    if obj.Parent ~= SpawnedEssences then return end
    local rarity = getRarity(obj.Name)
    if rarity then
        task.wait(0.1)
        registerEssence(obj, rarity)
    end
end

SpawnedEssences.ChildAdded:Connect(checkChild)

for _, obj in ipairs(SpawnedEssences:GetChildren()) do
    checkChild(obj)
end

print("✅ [EssenceNotifier] Ready — watching Workspace.SpawnedEssences")
