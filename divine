-- Tracking
local tracked={}
local essenceFound=false

local function foundEssence()
    essenceFound=true
    HopBtn.Text="✅  ESSENCE FOUND!"
    HopBtn.TextColor3=Color3.fromRGB(80,255,120)
    dot.BackgroundColor3=Color3.fromRGB(80,255,120)
end

local function registerEssence(obj,rarity)
    if tracked[obj] then return end
    foundEssence()
    local bb,bbDist=addESP(obj,rarity)
    local row,rowDist=addRow(obj.Name,rarity)
    tracked[obj]={bb=bb,row=row}
    task.spawn(function()
        while obj and obj.Parent do
            local my=getMyPos() local es=getPos(obj)
            if my and es then
                local d=math.floor((my-es).Magnitude)
                if rowDist and rowDist.Parent then rowDist.Text=d.." m" end
                if bbDist and bbDist.Parent then bbDist.Text=d.." m" end
            end
            task.wait(0.5)
        end
    end)
    showPopup(obj.Name,rarity)
    playAlert(rarity)
    obj.AncestryChanged:Connect(function(_,p)
        if p~=nil then return end
        local d=tracked[obj]
        if d then
            if d.bb and d.bb.Parent then d.bb:Destroy() end
            if d.row and d.row.Parent then d.row:Destroy() end
            tracked[obj]=nil resize()
        end
    end)
end

local function checkChild(obj)
    if obj.Parent~=SE then return end
    local r=getRarity(obj.Name)
    if r then task.wait(0.1) registerEssence(obj,r) end
end

SE.ChildAdded:Connect(checkChild)
for _,obj in ipairs(SE:GetChildren()) do checkChild(obj) end

-- Auto server hop
local hopping=false

local function stopHop()
    hopping=false
    if not essenceFound then
        HopBtn.Text="🔍  SERVER HOP"
        HopBtn.TextColor3=Color3.fromRGB(180,180,220)
    end
end

local function doHop()
    if hopping then stopHop() return end
    if essenceFound then return end
    hopping=true
    HopBtn.Text="⏳  HOPPING..."
    HopBtn.TextColor3=Color3.fromRGB(255,200,80)
    dot.BackgroundColor3=Color3.fromRGB(255,200,80)

    task.spawn(function()
        local placeId=game.PlaceId
        local cursor=""

        while hopping and not essenceFound do
            local ok,raw=pcall(function()
                return game:HttpGet("https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Asc&limit=100"..(cursor~="" and"&cursor="..cursor or""))
            end)
            if not ok then task.wait(2) continue end

            local ok2,data=pcall(function() return HttpService:JSONDecode(raw) end)
            if not ok2 or not data or not data.data then task.wait(2) continue end

            local servers=data.data
            -- Shuffle
            for i=#servers,2,-1 do
                local j=math.random(1,i)
                servers[i],servers[j]=servers[j],servers[i]
            end

            for _,server in ipairs(servers) do
                if not hopping or essenceFound then break end
                if server.id~=game.JobId and server.playing and server.maxPlayers and server.playing<server.maxPlayers then
                    HopBtn.Text="🚀  JOINING..."
                    HopBtn.TextColor3=Color3.fromRGB(80,180,255)
                    task.wait(0.5)
                    pcall(function()
                        TeleportService:TeleportToPlaceInstance(placeId,server.id,LocalPlayer)
                    end)
                    task.wait(8)
                end
            end

            cursor=data.nextPageCursor or ""
            if cursor=="" then cursor="" end
            task.wait(0.5)
        end
    end)
end

-- Button toggles hop on/off
HopBtn.MouseButton1Click:Connect(doHop)
