-- Auto-resize panel to fit entries
local HEADER_H  = 36
local PADDING   = 8
local EMPTY_H   = 36
local ENTRY_H   = 44

local function resizePanel()
    local count = #EssenceList:GetChildren() - 1 -- minus UIListLayout
    if count <= 0 then
        EmptyLabel.Visible = true
        EssenceList.Size   = UDim2.new(1, -8, 0, 0)
        Panel.Size         = UDim2.new(0, 260, 0, HEADER_H + PADDING + EMPTY_H)
    else
        EmptyLabel.Visible = false
        local h = count * ENTRY_H + (count - 1) * 4
        EssenceList.Size  = UDim2.new(1, -8, 0, h)
        Panel.Size        = UDim2.new(0, 260, 0, HEADER_H + PADDING + h + PADDING)
    end
end
